# Server
PORT=8080
DATABASE_URL=sqlite://data.db

# Data sources
ETHERSCAN_API_KEY=your_etherscan_key_here
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Alerts worker
ALERT_POLL_SECONDS=60

# CORS: comma-separated list of origins allowed to call this API from a
# browser (e.g. https://yourapp.com). Leave unset only for local dev —
# an empty value falls back to wide-open CORS, logged as a warning.
ALLOWED_ORIGINS=

# Public URL this app is reachable at — used to build Stripe Checkout
# success/cancel redirect links. For local dev, leave as-is.
APP_BASE_URL=http://localhost:8080

# Stripe — real Checkout + signature-verified webhook (see src/security.rs
# and src/services/stripe.rs). Get these from your Stripe Dashboard:
# - STRIPE_SECRET_KEY: Developers -> API keys -> Secret key (sk_...)
# - STRIPE_PRICE_ID: Product catalog -> your subscription price (price_...)
# - STRIPE_WEBHOOK_SECRET: Developers -> Webhooks -> your endpoint -> Signing secret (whsec_...)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (API key recovery) — via Resend (https://resend.com), a simple
# REST email API, no SMTP setup needed. If RESEND_API_KEY is left blank,
# recovered keys are logged server-side instead of emailed (dev-only).
RESEND_API_KEY=
EMAIL_FROM=Ledger <onboarding@resend.dev>
